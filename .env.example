# Скопируйте этот файл в .env и заполните значения.
# Не коммитьте .env в репозиторий (должен быть в .gitignore).

# Режим запуска при "python main.py" без аргументов и при "python main.py run":
#   cli     — подсказка по командам (по умолчанию)
#   telegram — запуск Telegram-бота
RUN_MODE=telegram

# Токен Telegram-бота от @BotFather.
# Получить: https://t.me/BotFather → /newbot → скопировать токен.
# Оставьте пустым, если используете только CLI.
TELEGRAM_BOT_TOKEN=
